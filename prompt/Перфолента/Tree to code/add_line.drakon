{"params":"<p>text<\/p>","items":{"4":{"type":"action","content":"<p>indent = repeat space(depth * 4)<\/p>","one":"5"},"1":{"type":"end"},"5":{"type":"action","content":"<p>line = indent + text<\/p>","one":"6"},"2":{"type":"branch","one":"3","branchId":0},"6":{"type":"action","content":"<p>Add line to lines<\/p>","one":"1"},"3":{"type":"action","content":"<p>Take from context:<\/p><ul><li>depth<\/li><li>lines<\/li><\/ul>","one":"4"}},"type":"drakon"}