            "branchId": 1,
            "one": "3",
            "content": "Read children"
        },
        "3": {
            "type": "action",
            "one": "5",
            "content": "children = await tools.readChildren(\n    folder\n)"
        },
        "4": {
            "type": "branch",
            "one": "1",
            "branchId": 3,
            "content": "Exit"
        },
        "5": {
            "type": "branch",
            "one": "7",
            "branchId": 2,
            "content": "Scan children"
        },
        "6": {
            "type": "loopend",
            "one": "4",
            "content": ""
        },
        "7": {
