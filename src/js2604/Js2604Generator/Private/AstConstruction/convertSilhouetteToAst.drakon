            "content": "reportError(\n    \"Non-unique branch name\",\n    fun.path,\n    branch.id\n)"
        },
        "13": {
            "type": "action",
            "one": "14",
            "content": "return "
        },
        "14": {
            "type": "action",
            "one": "6",
            "content": "gBranches[branch.name] = branch"
        },
        "15": {
            "type": "question",
            "one": "18",
            "two": "19",
            "flag1": 1,
            "content": "isSimpleSilhouette(tree.branches)"
        },
        "16": {
            "type": "action",
            "one": "4",
            "content": "convertNodesToAst(\n    tree.branches[0].body,\n    functionBody\n)"
        },
        "17": {
            "type": "action",
            "one": "4",
            "content": "buildComplexSilhouette(\n    fun,\n    tree,\n    functionBody\n)"
        },
