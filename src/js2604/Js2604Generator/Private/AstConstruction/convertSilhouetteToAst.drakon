            "type": "action",
            "one": "7",
            "content": "gBranches = {}"
        },
        "4": {
            "type": "branch",
            "one": "38",
            "branchId": 4,
            "content": "Exit"
        },
        "5": {
            "type": "branch",
            "one": "23",
            "branchId": 3,
            "content": "Which silhouette type?"
        },
        "6": {
            "type": "loopend",
            "one": "29",
            "content": ""
        },
