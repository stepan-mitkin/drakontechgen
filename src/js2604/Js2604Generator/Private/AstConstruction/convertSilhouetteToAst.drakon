            "flag1": 1,
            "content": "branch.name"
        },
        "9": {
            "type": "action",
            "one": "10",
            "content": "reportError(\n    \"Branch name cannot be empty\",\n    fun.path,\n    branch.id\n)"
        },
        "10": {
            "type": "action",
            "one": "11",
            "content": "return "
        },
        "11": {
