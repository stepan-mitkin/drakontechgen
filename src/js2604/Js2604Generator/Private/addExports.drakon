        },
        "22": {
            "type": "action",
            "one": "30",
            "two": "",
            "content": "code = \"module.exports = {\" + exported.join(\n    \", \"\n) + \"}\""
        },
        "28": {
            "type": "action",
            "one": "30",
            "content": "code = exported.map(\n    name => \"window.\" + name + \"=\" + name\n).join(\"\\n\")"
        },
        "30": {
            "type": "action",
            "one": "31",
            "two": "",
            "content": "parsed = options.esprima.parseScript(\n    code,\n    {loc: false }\n)"
        },
        "31": {
            "type": "action",
            "one": "32",
            "two": "",
            "content": "exportSrc = options.escodegen.generate(\n    parsed\n)"
        },
        "32": {
            "type": "action",
            "one": "13",
            "two": "",
            "content": "return src + \"\\n\" + exportSrc"
        },
        "33": {
            "type": "action",
            "one": "35",
            "content": "lines = exported.map(\n    name => \"unit.\" + name + \"=\" + name\n)"
        },
        "34": {
            "type": "action",
            "one": "30",
            "content": "code = lines.join(\"\\n\")"
        },
        "35": {
            "type": "action",
