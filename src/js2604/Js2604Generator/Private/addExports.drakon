            "content": "lines.push(line)"
        },
        "40": {
            "type": "action",
            "one": "39",
            "content": "line = \"Object.defineProperty(unit,'\" + dep\n+ \"',{get:function(){return \" + dep + \";},set:function(newValue){\"\n+ dep + \"=newValue;},enumerable:true,configurable:true});\""
        }
    }
