#ИспользоватьСтандартнуюБиблиотеку
ИмпортИмён Промкод.Перфолента.Консоль
ИмпортИмён Промкод.Перфолента.КодировкаТекста

Программа Классы
    
    Процедура Старт()
        Перем инфо тип ПолнаяИнформация = Неопределено
        Перем сер тип Серый = Неопределено
        Консоль.КодировкаВыходногоПотока = КодировкаТекста.cp866
        сер = Новый Серый("Луня", "полосатый")
        ВыводСтроки сер.Приветствовать()
        сер.ЗадатьАдрес("За тридевять земель")
        инфо = сер.ПолучитьПолнуюИнформацию()
        ВыводСтроки инфо.Цвет + " " + инфо.Имя + " " + инфо.Адрес
        ВыводСтроки "Проверка классов закончена"
        ВводСтроки
    КонецПроцедуры
КонецПрограммы

&ВидноВсем
Класс ПолнаяИнформация
    &ВидноВсем 
    Свойство Имя тип Строка
    &ВидноВсем 
    Свойство Цвет тип Строка
    &ВидноВсем 
    Свойство Адрес тип Строка
КонецКласса

&ВидноВсем
Класс Серый
    &ВидноВсем 
    Свойство Имя тип Строка
    &ВидноВсем 
    Свойство Цвет тип Строка
    &ВидноВсем 
    Свойство Обращение тип Строка
    &ВидноВсем 
    Свойство Приветствие тип Строка
    &ВидноВсем 
    Свойство Адрес тип Строка
    
    &ВидноВсем
    Конструктор(имяАрг тип Строка, цветАрг тип Строка)
        Обращение = "доктор"
        Приветствие = "Здравствуйте"
        Имя = имяАрг
        Цвет = цветАрг
    КонецКонструктора
    
    &ВидноВсем
    Процедура ЗадатьАдрес(адресАрг тип Строка)
        Лог("ЗадатьАдрес: " + адресАрг)
        Адрес = адресАрг
    КонецПроцедуры
    
    Процедура Лог(сообщение тип Строка)
        ВыводСтроки "Серый: " + сообщение
    КонецПроцедуры
    
    &ВидноВсем
    Функция ПолучитьПолнуюИнформацию() тип ПолнаяИнформация
        Перем результат тип ПолнаяИнформация = Новый ПолнаяИнформация
        Лог("ПолучитьПолнуюИнформацию")
        результат.Имя = Имя
        результат.Цвет = Цвет
        результат.Адрес = Адрес
        Возврат результат
    КонецФункции
    
    &ВидноВсем
    Функция Приветствовать() тип Строка
        Перем сообщение тип Строка = Неопределено
        Лог("Приветствовать")
        сообщение = Приветствие + ", " + Обращение + " " +
        Имя + "!"
        Возврат сообщение
    КонецФункции
КонецКласса